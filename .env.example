# ──────────────────────────────────────────────
# Environment configuration
#  Environment Variables
# ──────────────────────────────────────────────

# Reddit API (required for data scraping)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=MarketSentimentEngine/1.0

# OpenAI (optional — only if using LLM features)
OPENAI_API_KEY=your_openai_key

# ─── PostgreSQL Database ────────────────────────
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/market_sentinel
POSTGRES_DB=market_sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel

# Environment
MSE_ENV=default
